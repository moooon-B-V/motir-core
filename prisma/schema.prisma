// Prodect — prodect-core schema
//
// Subtask 1.1.3 lands the auth tables. Better-Auth (configured in 1.1.2 +
// adapter-wired in this Subtask via @better-auth/prisma-adapter) consumes
// these as its persistence layer.
//
// Subtask 1.2.2 adds the workspaces layer (Workspace + WorkspaceMembership).
// Workspaces are the tenant boundary: every workspace-scoped table in later
// Stories (projects, work items, …) carries a non-null workspaceId FK with
// onDelete: Cascade. The WorkspaceMembership join table lets a single User
// belong to one-or-more workspaces (durable B2B SaaS shape — Linear/Notion/
// GitHub all use the same pattern; the single-FK shortcut is forbidden per
// notes.html mistake #28). The role column ships with a 'member' default —
// a single role in v1, but the column exists durably so future RBAC lands
// without a schema migration. RLS policies + the workspace-context middle-
// ware are Subtask 1.2.3's territory; this Subtask is schema only.
//
// Field naming follows Better-Auth's adapter conventions so the adapter
// requires zero custom field mapping. Concretely that means:
//   - User.emailVerified is Boolean, not "emailVerifiedAt: DateTime?"
//     (Better-Auth tracks the verified-at moment via the Verification table
//     when it cares; the boolean is the canonical session-gating field).
//   - The password hash lives on the Account row (Account.password) under
//     providerId="credential", not on User. A single User can have BOTH a
//     credential Account and OAuth Account rows (Story 1.1.4's Google sign-in).
//   - OAuth account state uses providerId / accountId (not provider /
//     providerAccountId) and accessTokenExpiresAt / refreshTokenExpiresAt
//     (not a single expiresAt). These names match the Better-Auth
//     accountSchema in @better-auth/core verbatim.
//   - All `id` fields are plain `String`, not UUID. Better-Auth generates its
//     own URL-safe random strings (base62-ish) for primary keys and inserts
//     them via the adapter; declaring the column as Postgres UUID would
//     reject those strings outright (Better-Auth would error with P2007
//     "invalid input syntax for type uuid"). The repo's direct-DB code
//     paths fall back to Prisma's `@default(cuid())` on inserts that
//     don't supply an id.
//
// Email uniqueness is enforced lowercase in the application layer: Better-Auth's
// userSchema transforms email to lowercase before persistence, and our repo
// layer in lib/users/repo.ts mirrors that for any direct-DB code paths. We
// rely on that normalization rather than Postgres CITEXT so the schema stays
// extension-free for fresh local dev.
//
// Prisma 7: the datasource URL lives in `prisma.config.ts` (a runtime
// adapter), not here. This file declares only the provider and the models.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  emailVerified Boolean  @default(false)
  name          String
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  accounts                  Account[]
  sessions                  Session[]
  workspaceMemberships      WorkspaceMembership[]
  // Back-relations for WorkItem (Story 1.4). A user reports many work items
  // (reporter — Restrict on the FK: a user with reported issues on record
  // cannot be hard-deleted) and can be assigned many (assignee — SetNull on
  // the FK: deleting an assignee leaves the issue unassigned, never removes
  // it). Named relations because there are two distinct User↔WorkItem edges.
  reportedWorkItems         WorkItem[]            @relation("WorkItemReporter")
  assignedWorkItems         WorkItem[]            @relation("WorkItemAssignee")
  // Back-relation for WorkItemLink (Subtask 1.4.3). A user creates many
  // issue-to-issue links (createdBy — Restrict: a user with links on record
  // cannot be hard-deleted, mirroring the reporter pattern).
  createdWorkItemLinks      WorkItemLink[]        @relation("WorkItemLinkCreatedBy")
  // Back-relation for WorkItemRevision (Subtask 1.4.6). A user authors many
  // revisions (changedBy — Restrict on the FK: a user with audit history on
  // record cannot be hard-deleted, mirroring the reporter pattern).
  authoredWorkItemRevisions WorkItemRevision[]    @relation("WorkItemRevisionAuthor")
  // Back-relation for Attachment (Subtask 2.3.7). A user uploads many
  // attachments (uploader — Cascade on the FK: deleting a user removes their
  // uploaded blobs' audit rows). Modelled to keep the schema graph in sync
  // with the migration-built FK (bug-attachment-fk-migration-drift).
  uploadedAttachments       Attachment[]

  @@map("user")
}

/// Both credential (email/password) AND OAuth provider linkages live here.
/// providerId = "credential" → Account.password holds the argon2 hash.
/// providerId = "google" (added in 1.1.4) → Account.accessToken /
/// refreshToken / idToken hold the OAuth tokens; Account.password is null.
/// Composite unique on (providerId, accountId) is Better-Auth's expected
/// shape — it's what makes findOrCreateOAuthUser's idempotency cheap.
model Account {
  id                    String    @id @default(cuid())
  userId                String
  providerId            String
  accountId             String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  /// Argon2id hash. Null for OAuth-only Account rows. The application layer
  /// only ever reads/writes this via lib/auth/passwords.ts.
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("account")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

/// Email-verification and password-reset tokens. Better-Auth's verification
/// table is keyed by (identifier, value) — `identifier` is typically the
/// user's email (for verification) or user id (for password reset), `value`
/// is the opaque token Better-Auth generates and emails out.
model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

/// Tenant boundary. Every workspace-scoped row (projects, work items, …)
/// FKs against Workspace.id with onDelete: Cascade. The slug column is a
/// URL-safe handle; it's unique globally (not per-user) so workspace URLs
/// are sharable. subtaskPrMergeMode is consumed by Story 1.4 + Epic 4 —
/// see Story 1.4 § Merge modes.
model Workspace {
  id                 String             @id @default(cuid())
  name               String
  slug               String             @unique
  subtaskPrMergeMode SubtaskPrMergeMode @default(manual)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  memberships         WorkspaceMembership[]
  projects            Project[]
  workItems           WorkItem[]
  workItemLinks       WorkItemLink[]
  jobRuns             JobRun[]
  jobRunDlqs          JobRunDlq[]
  workflowStatuses    WorkflowStatus[]
  workflowTransitions WorkflowTransition[]
  attachments         Attachment[]
  boards              Board[]
  boardColumns        BoardColumn[]
  boardColumnStatuses BoardColumnStatus[]
  sprints             Sprint[]

  @@map("workspace")
}

/// A Project groups work items inside a workspace (Story 1.3). The
/// `identifier` is a short (3-5 char) uppercase, workspace-unique handle
/// that prefixes work-item keys (e.g. "PROD-42"); `lastWorkItemNumber` is
/// the per-project monotonic counter producing the numeric suffix. That
/// counter is bumped via an UPDATE … RETURNING in the repository so
/// allocation is gap-free under concurrency. Projects are soft-deleted
/// (`archivedAt`) and NEVER hard-deleted — work-item history (Story 1.4)
/// must survive an archive. A workspace delete cascades the project; an
/// archive/delete clears a member's `activeProjectId` (onDelete: SetNull)
/// rather than cascading the membership away.
model Project {
  id                 String             @id @default(cuid())
  workspaceId        String
  name               String
  slug               String
  identifier         String
  lastWorkItemNumber Int                @default(0)
  /// Per-project status-transition enforcement mode (Story 2.2). `restricted`
  /// (default) consults the `workflow_transition` rows — only an explicit
  /// edge is a legal move. `open` ignores them: any status → any status is
  /// allowed. Storing the policy as a project column (not a flag on every
  /// transition row) keeps storage O(transitions) and the policy check O(1);
  /// flipping to `open` does NOT delete the curated transition rows, so a
  /// flip back to `restricted` restores the graph. Jira and Linear both ship
  /// this same "guarded vs anything-goes" project-level toggle.
  workflowPolicyMode WorkflowPolicyMode @default(restricted)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  archivedAt         DateTime?

  workspace           Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  // Back-relation for WorkspaceMembership.activeProject. Named explicitly
  // so Prisma's relation inference doesn't have to guess; there is exactly
  // ONE relation between Project and WorkspaceMembership (the active-project
  // pointer), and both sides carry the same @relation("ActiveProject") name.
  members             WorkspaceMembership[] @relation("ActiveProject")
  workItems           WorkItem[]
  workflowStatuses    WorkflowStatus[]
  workflowTransitions WorkflowTransition[]
  boards              Board[]
  boardColumns        BoardColumn[]
  boardColumnStatuses BoardColumnStatus[]
  sprints             Sprint[]

  @@unique([workspaceId, slug])
  @@unique([workspaceId, identifier])
  @@index([workspaceId])
  @@map("project")
}

/// Join table — a user belongs to one-or-more workspaces. Cascades on both
/// FKs: deleting a Workspace or a User removes the membership row. The
/// (userId, workspaceId) uniqueness prevents accidental double-inserts.
/// The role column ships with 'member' default; future RBAC reads this
/// without a schema migration.
model WorkspaceMembership {
  id              String   @id @default(cuid())
  userId          String
  workspaceId     String
  role            String   @default("member")
  /// The member's currently-active project within this workspace. Clears
  /// to NULL (onDelete: SetNull) — not cascades — when that project is
  /// archived/deleted, so losing a project never removes the membership.
  /// Resolution (getActiveProject) + RLS land in Subtask 1.3.2.
  activeProjectId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  activeProject Project?  @relation("ActiveProject", fields: [activeProjectId], references: [id], onDelete: SetNull)

  @@unique([userId, workspaceId])
  @@index([userId])
  @@index([workspaceId])
  @@index([activeProjectId])
  @@map("workspace_membership")
}

/// Workspace-level setting controlling whether Subtask PRs auto-merge into
/// the Story branch. Defaults to `manual` (developer-friendly review flow).
/// `review_on_fail` is reserved for a later Story that ships the CI-driven
/// gate; shipping the enum value now avoids a Postgres enum ALTER later.
enum SubtaskPrMergeMode {
  auto
  manual
  review_on_fail

  @@map("subtask_pr_merge_mode")
}

/// The unit of tracked work in Prodect's PM core (Story 1.4). Every epic,
/// story, task, bug, and subtask a team plans is a row here. Self-referencing
/// tree via `parentId`, with the kind-parent matrix, the 4-level depth limit,
/// and cycle prevention all enforced at the DB layer by PL/pgSQL triggers
/// (see prisma/sql/work_item_triggers.sql, applied in the add_work_items
/// migration). Those triggers — NOT a Prisma-level check — are the source of
/// truth for structural integrity; the repository translates their SQLSTATE
/// 23514 message markers into typed errors at its edge.
///
/// Two distinct user-visible content axes, both Markdown source rendered as
/// GFM (see lib/markdown/render.tsx):
///   - descriptionMd  — "what to do" (the actionable spec).
///   - explanationMd  — "why this matters" (the context a non-technical
///                       reviewer needs). Mostly AI-drafted in steady state,
///                       but the column is just text + a provenance enum; the
///                       closed-source AI logic lives in prodect-ai. The
///                       GPL boundary stays clean — this table can't tell an
///                       AI-drafted value from a hand-typed one except via
///                       `explanationSource`.
///
/// `key` is the per-project monotonic number allocated via
/// projectRepository.allocateWorkItemNumber (Story 1.3.1); `identifier`
/// ("PROD-42") is the denormalized `project.identifier + "-" + key` kept on
/// the row for index/search efficiency. `position` is a fractional index
/// (lib/workItems/positioning.ts) so reorders are O(1) writes. Soft-delete
/// only via `archivedAt` — work-item history must survive (the Project
/// pattern). RLS on this table lands in Subtask 1.4.5, not here.
model WorkItem {
  id                String                    @id @default(cuid())
  workspaceId       String
  projectId         String
  parentId          String?
  kind              WorkItemKind
  key               Int
  identifier        String // "PROD-42" — denormalized from project.identifier + key for search/index efficiency
  title             String
  descriptionMd     String?                   @db.Text // "what to do" — Markdown source
  explanationMd     String?                   @db.Text // "why this matters" — distinct from description; mostly AI-drafted, user-owned
  explanationSource WorkItemExplanationSource @default(user_authored)
  status            String                    @default("open")
  priority          WorkItemPriority          @default(medium)
  assigneeId        String?
  reporterId        String
  dueDate           DateTime?
  estimateMinutes   Int?
  position          String                    @db.Text
  // Agile association + backlog rank (Story 4.1). `sprintId` is the issue's
  // sprint (NULL = in the backlog); `onDelete: SetNull` so deleting/clearing a
  // sprint never deletes its issues (they fall back to the backlog). `backlogRank`
  // is the GLOBAL fractional-index ordering (the same opaque base-62 String the
  // `position` columns use, via lib/workItems/positioning.ts) that lets the
  // backlog (Story 4.2) and a sprint both be drag-reordered off one field —
  // SEPARATE from `position`, which orders the tree under a parent. Column names
  // stay camelCase to match this table's existing columns (the `board` table is
  // snake_case-mapped, but `work_item`'s 20 existing columns are not — within-table
  // consistency wins, decision-authority rung 2 > the card's `@map` prose).
  sprintId          String?
  backlogRank       String?                   @db.Text
  archivedAt        DateTime?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  workspace Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent    WorkItem?          @relation("WorkItemParent", fields: [parentId], references: [id], onDelete: NoAction)
  children  WorkItem[]         @relation("WorkItemParent")
  assignee  User?              @relation("WorkItemAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  reporter  User               @relation("WorkItemReporter", fields: [reporterId], references: [id], onDelete: Restrict)
  // The sprint side of the association. Modelled on BOTH sides (Sprint.workItems
  // back-relation) with the SetNull action the migration uses, so `migrate dev`
  // reports "No difference detected" — the FK-drift rule (bug-attachment-fk-migration-drift).
  sprint    Sprint?            @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  // Back-relations for WorkItemLink (Subtask 1.4.3). Two named relations
  // because there are two distinct WorkItem↔WorkItemLink edges (from/to).
  // Cascading delete on both sides: removing an issue removes its links.
  linksFrom WorkItemLink[]     @relation("LinksFrom")
  linksTo   WorkItemLink[]     @relation("LinksTo")
  // Audit trail (Subtask 1.4.6). A work item accrues many revision rows; the
  // FK cascades so hard-deleting an issue removes its history with it.
  revisions WorkItemRevision[]

  @@unique([projectId, key])
  @@unique([projectId, identifier])
  @@index([projectId, parentId, position])
  @@index([projectId, status])
  @@index([projectId, assigneeId])
  @@index([workspaceId])
  // Serves BOTH the backlog read (`sprintId IS NULL`, `backlogRank` order) and a
  // sprint's ranked issues (`sprintId = ?`, `backlogRank` order) off one composite.
  @@index([projectId, sprintId, backlogRank])
  @@map("work_item")
}

/// Many-to-many issue-to-issue relationships (Subtask 1.4.3). Models the four
/// link kinds Linear / Jira / GitHub all expose: `is_blocked_by` (dependency —
/// reading the AI planner's ready-set requires indexed traversal of this
/// table), `relates_to` (symmetric soft link), `duplicates`, `clones`.
///
/// Direction convention: the row reads "fromItem <kind> toItem" — so
/// `fromItem is_blocked_by toItem` means fromItem cannot start until toItem
/// is done. The `relates_to` reciprocal row (write A↔B → also persist B↔A) is
/// a SERVICE-layer concern (1.4.4); this repository writes one row per call.
///
/// `workspaceId` is denormalized from the fromItem for RLS speed: every link
/// query starts with a workspace gate, and pulling it from fromItem at query
/// time would require a join. The DB-layer trigger (see
/// prisma/sql/work_item_link_triggers.sql) keeps the denormalization honest —
/// it rejects any insert/update where fromItem.workspaceId ≠ toItem.workspaceId
/// (no cross-workspace links) or where NEW.workspaceId ≠ fromItem.workspaceId
/// (catches a service-layer bug that wrote the wrong workspaceId on the row).
///
/// Structural triggers (see work_item_link_triggers.sql):
///   - WI_LINK_CYCLE      — cycle prevention, scoped to `is_blocked_by` only.
///                          (relates_to is allowed to be reciprocal/cyclic by
///                           design — A relates_to B AND B relates_to A is the
///                           expected steady state for the symmetric kind.)
///   - WI_LINK_CROSS_WORKSPACE / WI_LINK_WORKSPACE_MISMATCH
///                        — workspaceId consistency (see above).
///   - WI_LINK_SELF       — fromId = toId rejected.
/// The repository translates these markers into the typed errors in
/// lib/workItems/linkErrors.ts at its edge (the 4-layer rule).
model WorkItemLink {
  id          String           @id @default(cuid())
  workspaceId String
  fromId      String
  toId        String
  kind        WorkItemLinkKind
  createdById String
  createdAt   DateTime         @default(now())

  fromItem  WorkItem  @relation("LinksFrom", fields: [fromId], references: [id], onDelete: Cascade)
  toItem    WorkItem  @relation("LinksTo", fields: [toId], references: [id], onDelete: Cascade)
  createdBy User      @relation("WorkItemLinkCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([fromId, toId, kind])
  @@index([toId, kind])
  @@index([fromId, kind])
  @@index([workspaceId])
  @@map("work_item_link")
}

// Durable audit trail for work-item mutations (Subtask 1.4.6). Every
// create / update / archive / link / unlink the service performs writes ONE
// revision row inside the SAME transaction as the mutation it describes
// (workItemsService → workItemRevisionsService.recordRevision), so the
// history can never diverge from the data. Epic 5's activity feed reads it,
// Epic 6's reporting sums over it, Epic 7 diffs "what changed since the last
// planning pass" off it.
//
// `changeKind` is a plain `String`, NOT a Postgres enum, deliberately: future
// kinds ('linked', 'unlinked', 'restored', …) must not require a Postgres
// `ALTER TYPE` migration. The service is the validation boundary — it only
// ever writes the values the WorkItemRevisionDto union constrains
// ('created' | 'updated' | 'archived'); the mapper's `as` cast at the read
// edge is what makes the DB-text → DTO-union narrowing safe.
//
// `diff` is JSON: the field-diff shape ({ title: { from, to }, … }) for
// create/update/archive, and the link-diff shape ({ links: { added: [...] } })
// for link/unlink. It is intentionally untyped at the DB layer — the DTO
// pins the wire shape.
//
// `onDelete: Restrict` on `changedById` mirrors WorkItem.reporter (1.4.2):
// revisions preserve history even after a user soft-deletes, so hard-deleting
// a user who ever changed an issue requires explicit handling (a future
// user-archive Story) rather than silently shredding the audit trail.
// `workItemId` cascades — when an issue is hard-deleted its history goes with
// it (work items are soft-archived in practice, so this is the rare path).
//
// NOTE: there is no `workspaceId` column by design — denormalizing tenancy
// onto a revision row would let it lie about which workspace it belongs to.
// The RLS policy (see the add_work_item_revisions migration) joins to the
// parent work_item instead.
model WorkItemRevision {
  id          String   @id @default(cuid())
  workItemId  String
  changedById String
  changedAt   DateTime @default(now())
  changeKind  String // 'created' | 'updated' | 'archived' — String, not enum (see model note)
  diff        Json

  workItem  WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  changedBy User     @relation("WorkItemRevisionAuthor", fields: [changedById], references: [id], onDelete: Restrict)

  @@index([workItemId, changedAt])
  @@index([workItemId])
  @@map("work_item_revision")
}

enum WorkItemLinkKind {
  is_blocked_by
  relates_to
  duplicates
  clones

  @@map("work_item_link_kind")
}

enum WorkItemKind {
  epic
  story
  task
  bug
  subtask

  @@map("work_item_kind")
}

enum WorkItemPriority {
  lowest
  low
  medium
  high
  highest

  @@map("work_item_priority")
}

enum WorkItemExplanationSource {
  user_authored
  ai_draft
  user_edited

  @@map("work_item_explanation_source")
}

/// A per-project, customizable issue status (Story 2.2). Every project owns an
/// ordered set of these; `work_item.status` stores the `key` of one of them.
/// `category` is the durable Jira-style three-bucket taxonomy (todo /
/// in_progress / done) every later surface groups by — boards (Epic 3) draw a
/// column per status, reports (Epic 6) filter/group by category, and Story
/// 1.4's readiness predicate generalizes "terminal" from a hardcoded 'done'
/// string to `category = done` (finding #21).
///
/// Tenancy mirrors `work_item`: an explicit non-null `workspaceId` column +
/// `projectId` FK, with RLS (ENABLE + FORCE) gating on `app.workspace_id`.
/// There is NO system-admin escape hatch here (unlike `job_run`): these rows
/// are pure tenant data with a non-null workspaceId, always written under an
/// active workspace context (the 2.2.2 seed runs inside createProject's
/// withWorkspaceContext transaction) — exactly like `project`/`work_item`, so
/// the policy is their pure workspace gate. See the add_workflow_status_and_
/// transition_rls migration for the rationale.
///
/// `position` is a fractional index (the SAME `String`/`lib/workItems/
/// positioning.ts` shape `work_item.position` uses — opaque base-62 keys that
/// sort lexicographically), so a status reorder is a single-row write. (The
/// 2.2.1 card's "Decimal(20,10)" wording contradicts its own "same
/// fractional-indexing path the work-item ordering uses" clause; the shipped
/// ordering path is string-keyed, so `String @db.Text` is the consistent
/// shape — decision-authority rung 2 over rung 3.)
///
/// `color` is an OPTIONAL per-status hex override; null means "derive from the
/// category" (the Jira default, where category drives the swatch). `isInitial`
/// marks the one status new work items land in; a partial unique index
/// (`workflow_status_one_initial_per_project`, in the migration — Prisma can't
/// express a partial index in the DSL) enforces exactly one initial status per
/// project. Seeding the default rows is 2.2.2's job (application-layer, under
/// the request's workspace context — NOT a SQL INSERT in the migration).
model WorkflowStatus {
  id          String         @id @default(cuid())
  workspaceId String         @map("workspace_id")
  projectId   String         @map("project_id")
  key         String
  label       String
  category    StatusCategory
  color       String?
  position    String         @db.Text
  isInitial   Boolean        @default(false) @map("is_initial")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  workspace           Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project             Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  // A transition references two statuses (from / to); both edges cascade so
  // deleting a status removes the transitions that touch it.
  transitionsFrom     WorkflowTransition[] @relation("WorkflowTransitionFrom")
  transitionsTo       WorkflowTransition[] @relation("WorkflowTransitionTo")
  // Board columns this status is mapped into (Story 3.1). Cascades: deleting a
  // status removes its column mappings (a card whose status vanished can't sit
  // in a column keyed on it).
  boardColumnStatuses BoardColumnStatus[]

  // `key` is the machine-stable handle work_item.status stores; unique per
  // project. The partial "exactly one initial per project" unique index is
  // raw SQL in the migration (not expressible here).
  @@unique([projectId, key])
  @@index([workspaceId])
  @@index([projectId, position])
  @@map("workflow_status")
}

/// A legal status move within a project (Story 2.2). One row = one directed
/// edge `fromStatus → toStatus`. Consulted only when the project's
/// `workflowPolicyMode = restricted`; under `open` these rows are ignored at
/// validation time (but kept, so flipping back to `restricted` restores the
/// curated graph). The denormalized non-null `workspaceId` mirrors
/// `work_item_link` — it makes the RLS gate a direct comparison (no join) and
/// is kept honest by the FK chain (both endpoints + the project share one
/// workspace). Same pure-workspace-gate RLS as `workflow_status`.
model WorkflowTransition {
  id           String   @id @default(cuid())
  workspaceId  String   @map("workspace_id")
  projectId    String   @map("project_id")
  fromStatusId String   @map("from_status_id")
  toStatusId   String   @map("to_status_id")
  createdAt    DateTime @default(now()) @map("created_at")

  workspace  Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project    Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fromStatus WorkflowStatus @relation("WorkflowTransitionFrom", fields: [fromStatusId], references: [id], onDelete: Cascade)
  toStatus   WorkflowStatus @relation("WorkflowTransitionTo", fields: [toStatusId], references: [id], onDelete: Cascade)

  // No duplicate edges between the same ordered pair within a project.
  @@unique([projectId, fromStatusId, toStatusId])
  @@index([workspaceId])
  @@index([projectId])
  @@index([fromStatusId])
  @@index([toStatusId])
  @@map("workflow_transition")
}

/// The Jira-style three-bucket status taxonomy. Every `workflow_status` falls
/// in exactly one bucket; downstream surfaces (boards, reports, the readiness
/// predicate) group/branch on this, not on the per-project `key`. Closed +
/// stable set, so a Postgres enum (unlike `work_item.status`, kept a String
/// for per-project customizability/portability).
enum StatusCategory {
  todo
  in_progress
  done

  @@map("status_category")
}

/// Per-project transition-enforcement mode (`project.workflowPolicyMode`).
/// `restricted` = only explicit `workflow_transition` edges are legal;
/// `open` = any status → any status. Default `restricted`.
enum WorkflowPolicyMode {
  restricted
  open

  @@map("workflow_policy_mode")
}

/// A board (Story 3.1) is a per-project READ PROJECTION over issues — columns
/// of cards, where a card's column is DERIVED from its `work_item.status`,
/// never stored as board-local placement. A project owns one-or-more boards;
/// v1 auto-seeds exactly ONE Kanban board (Subtask 3.1.2). `projectId` is a
/// plain FK and is deliberately NOT unique, so multiple-boards-per-project is
/// a non-breaking later addition (board CRUD is post-v1). The Scrum
/// sprint-scoped board is Story 3.4 — `BoardType.scrum` ships now so 3.4 adds
/// no enum migration. RLS is the pure workspace gate (non-null `workspace_id`,
/// every write under an active workspace context) — same as `workflow_status`
/// / `project` / `work_item`, with NO system-admin escape hatch.
model Board {
  id              String               @id @default(cuid())
  workspaceId     String               @map("workspace_id")
  projectId       String               @map("project_id")
  name            String
  type            BoardType            @default(kanban)
  // The project's ONE default board (Story 3.7.2). Multiple boards per project
  // now exist (CRUD is 3.7.3); exactly one is the default — the board `/boards`
  // opens when no `?board=` is given. The invariant ("at most one default per
  // project") is enforced by a PARTIAL unique index in the migration
  // (`board_one_default_per_project`, `WHERE is_default`) — Prisma's DSL can't
  // express a filtered unique index, so it lives as raw SQL there, exactly like
  // `workflow_status_one_initial_per_project`. The 3.1-seeded board backfills to
  // `true`; `seedDefaultBoard` sets it on every new project's first board.
  isDefault       Boolean              @default(false) @map("is_default")
  // Stable switcher ordering (Story 3.7.2). The SAME opaque base-62 fractional-
  // index String the `work_item` / `board_column` / `workflow_status` positions
  // use (`lib/workItems/positioning.ts`) — app-assigned (no DB default), so a
  // reorder is a single-row write. Seeded/backfilled to the first key (`a0`).
  position        String               @db.Text
  // Swimlane grouping (Story 3.3.2). `none` is the flat 3.2 board (the default,
  // so every existing/seeded board is unchanged). The 3.3.4 projection resolves
  // each card's lane server-side from this value (epic groups by ANCESTOR epic).
  swimlaneGroupBy BoardSwimlaneGroupBy @default(none) @map("swimlane_group_by")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  workspace      Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project        Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  columns        BoardColumn[]
  columnStatuses BoardColumnStatus[]

  @@index([workspaceId])
  // Non-unique — a project has N boards (3.7); the switcher lists them by
  // `position` (3.7.2), so the lookup is ordered on this composite index.
  @@index([projectId, position])
  @@map("board")
}

/// An ordered column on a board (Story 3.1). It maps to a SET of workflow
/// statuses via `board_column_status` (many statuses → one column — the Jira
/// "merge In Progress + In Review" shape). `position` is the SAME opaque
/// base-62 fractional-index String the `work_item` / `workflow_status` columns
/// use (`lib/workItems/positioning.ts`) — a column reorder is a single-row
/// rewrite needing no new mechanism. (The 3.1.1 card said `Decimal(20,10)`
/// citing finding #18, but the shipped position columns are `String @db.Text`;
/// per the decision-authority ladder shipped code wins — see the migration
/// header.) `wipLimit` ships nullable now so Story 3.3 (WIP enforcement) adds
/// no migration; THIS story only persists the column — no enforcement.
model BoardColumn {
  id          String   @id @default(cuid())
  workspaceId String   @map("workspace_id")
  projectId   String   @map("project_id")
  boardId     String   @map("board_id")
  name        String
  position    String   @db.Text
  wipLimit    Int?     @map("wip_limit")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  workspace      Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project        Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  board          Board               @relation(fields: [boardId], references: [id], onDelete: Cascade)
  statusMappings BoardColumnStatus[]

  @@index([workspaceId])
  @@index([boardId, position])
  @@map("board_column")
}

/// The column ↔ status mapping (Story 3.1). One row links one `workflow_status`
/// to one `board_column`. `@@unique([boardId, statusId])` enforces that a
/// status maps to AT MOST ONE column per board (many statuses MAY share a
/// column, but a status is never in two columns at once). A project status
/// with NO row here is UNMAPPED — surfaced by the 3.1.4 projection's
/// `unmappedStatuses`, never shown as a column and never silently dropped.
model BoardColumnStatus {
  id          String   @id @default(cuid())
  workspaceId String   @map("workspace_id")
  projectId   String   @map("project_id")
  boardId     String   @map("board_id")
  columnId    String   @map("column_id")
  statusId    String   @map("status_id")
  createdAt   DateTime @default(now()) @map("created_at")

  workspace Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  board     Board          @relation(fields: [boardId], references: [id], onDelete: Cascade)
  column    BoardColumn    @relation(fields: [columnId], references: [id], onDelete: Cascade)
  status    WorkflowStatus @relation(fields: [statusId], references: [id], onDelete: Cascade)

  @@unique([boardId, statusId])
  @@index([workspaceId])
  @@index([columnId])
  @@map("board_column_status")
}

/// Board kind (Story 3.1). `kanban` is the v1 default auto-seeded per project;
/// `scrum` (the sprint-scoped board) is Story 3.4 — the value exists now so
/// 3.4 adds no enum ALTER.
enum BoardType {
  kanban
  scrum

  @@map("board_type")
}

/// Board swimlane grouping (Story 3.3 · Subtask 3.3.2). The dimension a board's
/// cards are sliced into horizontal lanes by. `none` is the flat 3.2 board (the
/// DEFAULT — `board.swimlaneGroupBy @default(none)`, so every existing/seeded
/// board is unchanged and needs no backfill). `assignee` / `epic` / `priority`
/// are the stub-specified group-by dimensions; the lane a card lands in is
/// resolved server-side by the Story-3.3.4 projection (epic groups by the
/// ANCESTOR epic, not the immediate parent). Adding a value later (e.g. a
/// custom-query lane) is a non-breaking enum addition — same as `BoardType.scrum`
/// shipping ahead of Story 3.4.
enum BoardSwimlaneGroupBy {
  none
  assignee
  epic
  priority

  @@map("board_swimlane_group_by")
}

/// A Sprint — the unit of Agile time-boxing (Story 4.1). Scoped to a PROJECT,
/// not a board: a board in this product is a per-project READ projection (Story
/// 3.1), not Jira's cross-project saved-filter view, so a project has a single
/// logical sprint sequence regardless of how many scrum boards (Story 3.7) view
/// it. (Justified rung-1 deviation from Jira's `originBoardId` — see
/// scripts/plan-seed/data/story-4.1.ts.) `workspaceId` is denormalized for the
/// pure-workspace RLS gate, matching `board` / `work_item`.
///
/// State machine `planned → active → complete` (one-way: no skip, no reopen) is
/// enforced in the service layer (`assertSprintTransition`, Story 4.1.3). The
/// "one active sprint per project" invariant is a PARTIAL unique index
/// (`sprint_one_active_per_project`, `WHERE state = 'active'`) — Prisma's DSL
/// can't express a filtered unique index, so it lives as raw SQL in the
/// migration, exactly like `board_one_default_per_project`.
///
/// 4.1 ships the ENTITY + its CRUD rules; Story 4.4 owns the lifecycle
/// ORCHESTRATION (`startDate`/`endDate` stamped on *start*, `completedAt` on
/// *complete*, scope-lock, carry-over, sprint report). `sequence` is the
/// per-project monotonic ordinal that produces the default name ("Sprint N")
/// and a stable listing.
model Sprint {
  id          String      @id @default(cuid())
  workspaceId String      @map("workspace_id")
  projectId   String      @map("project_id")
  name        String
  goal        String?     @db.Text
  state       SprintState @default(planned)
  startDate   DateTime?   @map("start_date")
  endDate     DateTime?   @map("end_date")
  completedAt DateTime?   @map("completed_at")
  sequence    Int
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  workspace Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  // Back-relation for WorkItem.sprint. The FK lives on work_item with
  // onDelete: SetNull (deleting a sprint frees its issues to the backlog).
  workItems WorkItem[]

  @@index([workspaceId])
  // Resolve the active sprint + list a project's sprints.
  @@index([projectId, state])
  @@map("sprint")
}

/// Sprint lifecycle state (Story 4.1). `planned → active → complete`, mirroring
/// Jira's future/active/closed. All three values exist now so Story 4.4 (start /
/// complete flows) adds no enum ALTER — same pattern as `BoardType.scrum`
/// shipping ahead of Story 3.4.
enum SprintState {
  planned
  active
  complete

  @@map("sprint_state")
}

// Background-job run ledger (Story 1.6 · Subtask 1.6.2). Every invocation of a
// `defineJob`-wrapped Inngest function writes ONE row here: a `running` row at
// start, flipped to `succeeded` / `failed` on completion. This is the read
// path the operator dashboard (1.6.5) renders WITHOUT calling Inngest's own
// API — Prodect owns its job-observability data.
//
// `workspaceId` is NULLABLE on purpose: most jobs are workspace-scoped (the
// durable invariant `sendEvent` enforces — every business event carries a
// workspaceId), but SYSTEM jobs (`system.ping` here, `system.daily-health-
// check` in 1.6.4) are untenanted and write a null-workspace row. The FK
// cascades: archiving/deleting a workspace removes its job-run history with it.
//
// RLS landed in Subtask 1.6.4 (migration add_job_run_dlq_and_rls), folded in
// alongside the dead-letter-queue table so the two policies + the new table
// land in one atomic migration-by-concern (mirrors PRODECT_FINDINGS #20's
// "create table + its policy in one migration" lesson). The policy is the
// workspace gate with a system-admin escape hatch (`app.system_admin = 'true'`)
// so the trusted wrapper can write rows for any/no workspace and operator
// tooling can see untenanted system rows — see the migration for the shape.
//
// `status` is a Postgres enum (running / succeeded / failed) — the set is closed
// and stable, unlike `WorkItemRevision.changeKind` (left as text precisely
// because its value set is open). `failure` is JSON: `{ message, stack, code? }`.
// `idempotencyKey` is the rendered template (1.6.4 wires the dedup semantics;
// the column ships now so the dashboard + dedup land without a later migration).
model JobRun {
  id             String       @id @default(cuid())
  workspaceId    String?      @map("workspace_id")
  functionId     String       @map("function_id")
  eventName      String       @map("event_name")
  eventId        String       @map("event_id")
  attempt        Int
  status         JobRunStatus
  startedAt      DateTime     @default(now()) @map("started_at")
  finishedAt     DateTime?    @map("finished_at")
  durationMs     Int?         @map("duration_ms")
  failure        Json?
  idempotencyKey String?      @map("idempotency_key")

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // Dashboard read paths (1.6.5): newest-first per workspace, and the same
  // filtered by status. The eventId / idempotencyKey indexes serve the
  // correlation + dedup lookups (1.6.4).
  @@index([workspaceId, startedAt(sort: Desc)])
  @@index([workspaceId, status, startedAt(sort: Desc)])
  @@index([eventId])
  @@index([idempotencyKey])
  @@map("job_run")
}

// Dead-letter queue for background jobs (Story 1.6 · Subtask 1.6.4). When a
// `defineJob`-wrapped function exhausts its retry budget (the final attempt
// throws), the wrapper writes ONE row here — inside the same transaction that
// flips the run's `job_run.status` to `failed` — capturing enough to REPLAY:
// the function id, the original event name + full payload, the final failure,
// and the attempt count. This is the durable operator surface the 1.6.5
// dashboard's DLQ tab reads from and the "Replay" button acts on; Inngest's
// own failure view stays available for deep tracing but is NOT the source of
// truth for operator action.
//
// Deliberately NOT FK'd to `job_run`: a DLQ entry is a self-contained replay
// record (it carries the event payload), so it survives independent of the
// ledger row and a future retention sweep can prune `job_run` without
// orphaning replayable failures. `workspaceId` is nullable (system/cross-
// workspace jobs) and cascades on workspace delete, exactly like `job_run`.
//
// `firstFailedAt` is the run's `started_at` (when the failing run began);
// `lastFailedAt` is the exhaustion timestamp. `replayedAt` is null until an
// operator replays the entry (stamped by `replayDLQ`, lib/jobs/dlq.ts).
model JobRunDlq {
  id            String    @id @default(cuid())
  workspaceId   String?   @map("workspace_id")
  functionId    String    @map("function_id")
  eventName     String    @map("event_name")
  eventData     Json      @map("event_data")
  failure       Json
  attempts      Int
  firstFailedAt DateTime  @default(now()) @map("first_failed_at")
  lastFailedAt  DateTime  @default(now()) @map("last_failed_at")
  replayedAt    DateTime? @map("replayed_at")

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // Dashboard DLQ-tab read path (1.6.5): newest-failure-first per workspace.
  @@index([workspaceId, lastFailedAt(sort: Desc)])
  @@map("job_run_dlq")
}

enum JobRunStatus {
  running
  succeeded
  failed

  @@map("job_run_status")
}

/// An uploaded blob (Subtask 2.3.7) — a description image/file persisted to
/// Vercel Blob. v1 is a billing/audit trail: it records WHO uploaded WHAT,
/// not which work_item references it (the Markdown body just holds the URL).
/// Epic 5's attachments panel adds the `workItemId` link + management UI and
/// REUSES this table + the upload service/route (finding #52). RLS = pure
/// workspace gate (mirrors workflow_status — non-null workspaceId, written
/// inside an active workspace context); policy is in the migration SQL.
/// `uploaderUserId`'s FK (cascade) is created in the 2.3.7 migration; this
/// model MODELS it as the `uploader` relation (with `User.uploadedAttachments`
/// as the back-relation) so the schema graph matches the migration-built DB.
/// Modelling it is required: a hand-managed FK with no `@relation` makes every
/// `prisma migrate dev` re-propose dropping it (bug-attachment-fk-migration-drift).
model Attachment {
  id               String   @id @default(cuid())
  workspaceId      String   @map("workspace_id")
  uploaderUserId   String   @map("uploader_user_id")
  blobUrl          String   @map("blob_url")
  mimeType         String   @map("mime_type")
  sizeBytes        Int      @map("size_bytes")
  originalFilename String   @map("original_filename")
  createdAt        DateTime @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  uploader  User      @relation(fields: [uploaderUserId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt(sort: Desc)])
  @@map("attachment")
}
