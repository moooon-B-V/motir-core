// Prodect — prodect-core schema
//
// Subtask 1.1.3 lands the auth tables. Better-Auth (configured in 1.1.2 +
// adapter-wired in this Subtask via @better-auth/prisma-adapter) consumes
// these as its persistence layer.
//
// Subtask 1.2.2 adds the workspaces layer (Workspace + WorkspaceMembership).
// Workspaces are the tenant boundary: every workspace-scoped table in later
// Stories (projects, work items, …) carries a non-null workspaceId FK with
// onDelete: Cascade. The WorkspaceMembership join table lets a single User
// belong to one-or-more workspaces (durable B2B SaaS shape — Linear/Notion/
// GitHub all use the same pattern; the single-FK shortcut is forbidden per
// notes.html mistake #28). The role column ships with a 'member' default —
// a single role in v1, but the column exists durably so future RBAC lands
// without a schema migration. RLS policies + the workspace-context middle-
// ware are Subtask 1.2.3's territory; this Subtask is schema only.
//
// Field naming follows Better-Auth's adapter conventions so the adapter
// requires zero custom field mapping. Concretely that means:
//   - User.emailVerified is Boolean, not "emailVerifiedAt: DateTime?"
//     (Better-Auth tracks the verified-at moment via the Verification table
//     when it cares; the boolean is the canonical session-gating field).
//   - The password hash lives on the Account row (Account.password) under
//     providerId="credential", not on User. A single User can have BOTH a
//     credential Account and OAuth Account rows (Story 1.1.4's Google sign-in).
//   - OAuth account state uses providerId / accountId (not provider /
//     providerAccountId) and accessTokenExpiresAt / refreshTokenExpiresAt
//     (not a single expiresAt). These names match the Better-Auth
//     accountSchema in @better-auth/core verbatim.
//   - All `id` fields are plain `String`, not UUID. Better-Auth generates its
//     own URL-safe random strings (base62-ish) for primary keys and inserts
//     them via the adapter; declaring the column as Postgres UUID would
//     reject those strings outright (Better-Auth would error with P2007
//     "invalid input syntax for type uuid"). The repo's direct-DB code
//     paths fall back to Prisma's `@default(cuid())` on inserts that
//     don't supply an id.
//
// Email uniqueness is enforced lowercase in the application layer: Better-Auth's
// userSchema transforms email to lowercase before persistence, and our repo
// layer in lib/users/repo.ts mirrors that for any direct-DB code paths. We
// rely on that normalization rather than Postgres CITEXT so the schema stays
// extension-free for fresh local dev.
//
// Prisma 7: the datasource URL lives in `prisma.config.ts` (a runtime
// adapter), not here. This file declares only the provider and the models.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  emailVerified Boolean  @default(false)
  name          String
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  accounts             Account[]
  sessions             Session[]
  workspaceMemberships WorkspaceMembership[]
  // Back-relations for WorkItem (Story 1.4). A user reports many work items
  // (reporter — Restrict on the FK: a user with reported issues on record
  // cannot be hard-deleted) and can be assigned many (assignee — SetNull on
  // the FK: deleting an assignee leaves the issue unassigned, never removes
  // it). Named relations because there are two distinct User↔WorkItem edges.
  reportedWorkItems    WorkItem[]            @relation("WorkItemReporter")
  assignedWorkItems    WorkItem[]            @relation("WorkItemAssignee")
  // Back-relation for WorkItemLink (Subtask 1.4.3). A user creates many
  // issue-to-issue links (createdBy — Restrict: a user with links on record
  // cannot be hard-deleted, mirroring the reporter pattern).
  createdWorkItemLinks WorkItemLink[]        @relation("WorkItemLinkCreatedBy")
  // Back-relation for WorkItemRevision (Subtask 1.4.6). A user authors many
  // revisions (changedBy — Restrict on the FK: a user with audit history on
  // record cannot be hard-deleted, mirroring the reporter pattern).
  authoredWorkItemRevisions WorkItemRevision[] @relation("WorkItemRevisionAuthor")

  @@map("user")
}

/// Both credential (email/password) AND OAuth provider linkages live here.
/// providerId = "credential" → Account.password holds the argon2 hash.
/// providerId = "google" (added in 1.1.4) → Account.accessToken /
/// refreshToken / idToken hold the OAuth tokens; Account.password is null.
/// Composite unique on (providerId, accountId) is Better-Auth's expected
/// shape — it's what makes findOrCreateOAuthUser's idempotency cheap.
model Account {
  id                    String    @id @default(cuid())
  userId                String
  providerId            String
  accountId             String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  /// Argon2id hash. Null for OAuth-only Account rows. The application layer
  /// only ever reads/writes this via lib/auth/passwords.ts.
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("account")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

/// Email-verification and password-reset tokens. Better-Auth's verification
/// table is keyed by (identifier, value) — `identifier` is typically the
/// user's email (for verification) or user id (for password reset), `value`
/// is the opaque token Better-Auth generates and emails out.
model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

/// Tenant boundary. Every workspace-scoped row (projects, work items, …)
/// FKs against Workspace.id with onDelete: Cascade. The slug column is a
/// URL-safe handle; it's unique globally (not per-user) so workspace URLs
/// are sharable. subtaskPrMergeMode is consumed by Story 1.4 + Epic 4 —
/// see Story 1.4 § Merge modes.
model Workspace {
  id                 String             @id @default(cuid())
  name               String
  slug               String             @unique
  subtaskPrMergeMode SubtaskPrMergeMode @default(manual)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  memberships   WorkspaceMembership[]
  projects      Project[]
  workItems     WorkItem[]
  workItemLinks WorkItemLink[]
  jobRuns       JobRun[]

  @@map("workspace")
}

/// A Project groups work items inside a workspace (Story 1.3). The
/// `identifier` is a short (3-5 char) uppercase, workspace-unique handle
/// that prefixes work-item keys (e.g. "PROD-42"); `lastWorkItemNumber` is
/// the per-project monotonic counter producing the numeric suffix. That
/// counter is bumped via an UPDATE … RETURNING in the repository so
/// allocation is gap-free under concurrency. Projects are soft-deleted
/// (`archivedAt`) and NEVER hard-deleted — work-item history (Story 1.4)
/// must survive an archive. A workspace delete cascades the project; an
/// archive/delete clears a member's `activeProjectId` (onDelete: SetNull)
/// rather than cascading the membership away.
model Project {
  id                 String    @id @default(cuid())
  workspaceId        String
  name               String
  slug               String
  identifier         String
  lastWorkItemNumber Int       @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  archivedAt         DateTime?

  workspace Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  // Back-relation for WorkspaceMembership.activeProject. Named explicitly
  // so Prisma's relation inference doesn't have to guess; there is exactly
  // ONE relation between Project and WorkspaceMembership (the active-project
  // pointer), and both sides carry the same @relation("ActiveProject") name.
  members   WorkspaceMembership[] @relation("ActiveProject")
  workItems WorkItem[]

  @@unique([workspaceId, slug])
  @@unique([workspaceId, identifier])
  @@index([workspaceId])
  @@map("project")
}

/// Join table — a user belongs to one-or-more workspaces. Cascades on both
/// FKs: deleting a Workspace or a User removes the membership row. The
/// (userId, workspaceId) uniqueness prevents accidental double-inserts.
/// The role column ships with 'member' default; future RBAC reads this
/// without a schema migration.
model WorkspaceMembership {
  id              String   @id @default(cuid())
  userId          String
  workspaceId     String
  role            String   @default("member")
  /// The member's currently-active project within this workspace. Clears
  /// to NULL (onDelete: SetNull) — not cascades — when that project is
  /// archived/deleted, so losing a project never removes the membership.
  /// Resolution (getActiveProject) + RLS land in Subtask 1.3.2.
  activeProjectId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  activeProject Project?  @relation("ActiveProject", fields: [activeProjectId], references: [id], onDelete: SetNull)

  @@unique([userId, workspaceId])
  @@index([userId])
  @@index([workspaceId])
  @@index([activeProjectId])
  @@map("workspace_membership")
}

/// Workspace-level setting controlling whether Subtask PRs auto-merge into
/// the Story branch. Defaults to `manual` (developer-friendly review flow).
/// `review_on_fail` is reserved for a later Story that ships the CI-driven
/// gate; shipping the enum value now avoids a Postgres enum ALTER later.
enum SubtaskPrMergeMode {
  auto
  manual
  review_on_fail

  @@map("subtask_pr_merge_mode")
}

/// The unit of tracked work in Prodect's PM core (Story 1.4). Every epic,
/// story, task, bug, and subtask a team plans is a row here. Self-referencing
/// tree via `parentId`, with the kind-parent matrix, the 4-level depth limit,
/// and cycle prevention all enforced at the DB layer by PL/pgSQL triggers
/// (see prisma/sql/work_item_triggers.sql, applied in the add_work_items
/// migration). Those triggers — NOT a Prisma-level check — are the source of
/// truth for structural integrity; the repository translates their SQLSTATE
/// 23514 message markers into typed errors at its edge.
///
/// Two distinct user-visible content axes, both Markdown source rendered as
/// GFM (see lib/markdown/render.tsx):
///   - descriptionMd  — "what to do" (the actionable spec).
///   - explanationMd  — "why this matters" (the context a non-technical
///                       reviewer needs). Mostly AI-drafted in steady state,
///                       but the column is just text + a provenance enum; the
///                       closed-source AI logic lives in prodect-ai. The
///                       GPL boundary stays clean — this table can't tell an
///                       AI-drafted value from a hand-typed one except via
///                       `explanationSource`.
///
/// `key` is the per-project monotonic number allocated via
/// projectRepository.allocateWorkItemNumber (Story 1.3.1); `identifier`
/// ("PROD-42") is the denormalized `project.identifier + "-" + key` kept on
/// the row for index/search efficiency. `position` is a fractional index
/// (lib/workItems/positioning.ts) so reorders are O(1) writes. Soft-delete
/// only via `archivedAt` — work-item history must survive (the Project
/// pattern). RLS on this table lands in Subtask 1.4.5, not here.
model WorkItem {
  id                String                    @id @default(cuid())
  workspaceId       String
  projectId         String
  parentId          String?
  kind              WorkItemKind
  key               Int
  identifier        String // "PROD-42" — denormalized from project.identifier + key for search/index efficiency
  title             String
  descriptionMd     String?                   @db.Text // "what to do" — Markdown source
  explanationMd     String?                   @db.Text // "why this matters" — distinct from description; mostly AI-drafted, user-owned
  explanationSource WorkItemExplanationSource @default(user_authored)
  status            String                    @default("open")
  priority          WorkItemPriority          @default(medium)
  assigneeId        String?
  reporterId        String
  dueDate           DateTime?
  estimateMinutes   Int?
  position          String                    @db.Text
  archivedAt        DateTime?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  workspace Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent    WorkItem?  @relation("WorkItemParent", fields: [parentId], references: [id], onDelete: NoAction)
  children  WorkItem[] @relation("WorkItemParent")
  assignee  User?      @relation("WorkItemAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  reporter  User       @relation("WorkItemReporter", fields: [reporterId], references: [id], onDelete: Restrict)
  // Back-relations for WorkItemLink (Subtask 1.4.3). Two named relations
  // because there are two distinct WorkItem↔WorkItemLink edges (from/to).
  // Cascading delete on both sides: removing an issue removes its links.
  linksFrom WorkItemLink[] @relation("LinksFrom")
  linksTo   WorkItemLink[] @relation("LinksTo")
  // Audit trail (Subtask 1.4.6). A work item accrues many revision rows; the
  // FK cascades so hard-deleting an issue removes its history with it.
  revisions WorkItemRevision[]

  @@unique([projectId, key])
  @@unique([projectId, identifier])
  @@index([projectId, parentId, position])
  @@index([projectId, status])
  @@index([projectId, assigneeId])
  @@index([workspaceId])
  @@map("work_item")
}

/// Many-to-many issue-to-issue relationships (Subtask 1.4.3). Models the four
/// link kinds Linear / Jira / GitHub all expose: `is_blocked_by` (dependency —
/// reading the AI planner's ready-set requires indexed traversal of this
/// table), `relates_to` (symmetric soft link), `duplicates`, `clones`.
///
/// Direction convention: the row reads "fromItem <kind> toItem" — so
/// `fromItem is_blocked_by toItem` means fromItem cannot start until toItem
/// is done. The `relates_to` reciprocal row (write A↔B → also persist B↔A) is
/// a SERVICE-layer concern (1.4.4); this repository writes one row per call.
///
/// `workspaceId` is denormalized from the fromItem for RLS speed: every link
/// query starts with a workspace gate, and pulling it from fromItem at query
/// time would require a join. The DB-layer trigger (see
/// prisma/sql/work_item_link_triggers.sql) keeps the denormalization honest —
/// it rejects any insert/update where fromItem.workspaceId ≠ toItem.workspaceId
/// (no cross-workspace links) or where NEW.workspaceId ≠ fromItem.workspaceId
/// (catches a service-layer bug that wrote the wrong workspaceId on the row).
///
/// Structural triggers (see work_item_link_triggers.sql):
///   - WI_LINK_CYCLE      — cycle prevention, scoped to `is_blocked_by` only.
///                          (relates_to is allowed to be reciprocal/cyclic by
///                           design — A relates_to B AND B relates_to A is the
///                           expected steady state for the symmetric kind.)
///   - WI_LINK_CROSS_WORKSPACE / WI_LINK_WORKSPACE_MISMATCH
///                        — workspaceId consistency (see above).
///   - WI_LINK_SELF       — fromId = toId rejected.
/// The repository translates these markers into the typed errors in
/// lib/workItems/linkErrors.ts at its edge (the 4-layer rule).
model WorkItemLink {
  id          String           @id @default(cuid())
  workspaceId String
  fromId      String
  toId        String
  kind        WorkItemLinkKind
  createdById String
  createdAt   DateTime         @default(now())

  fromItem  WorkItem  @relation("LinksFrom", fields: [fromId], references: [id], onDelete: Cascade)
  toItem    WorkItem  @relation("LinksTo", fields: [toId], references: [id], onDelete: Cascade)
  createdBy User      @relation("WorkItemLinkCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([fromId, toId, kind])
  @@index([toId, kind])
  @@index([fromId, kind])
  @@index([workspaceId])
  @@map("work_item_link")
}

// Durable audit trail for work-item mutations (Subtask 1.4.6). Every
// create / update / archive / link / unlink the service performs writes ONE
// revision row inside the SAME transaction as the mutation it describes
// (workItemsService → workItemRevisionsService.recordRevision), so the
// history can never diverge from the data. Epic 5's activity feed reads it,
// Epic 6's reporting sums over it, Epic 7 diffs "what changed since the last
// planning pass" off it.
//
// `changeKind` is a plain `String`, NOT a Postgres enum, deliberately: future
// kinds ('linked', 'unlinked', 'restored', …) must not require a Postgres
// `ALTER TYPE` migration. The service is the validation boundary — it only
// ever writes the values the WorkItemRevisionDto union constrains
// ('created' | 'updated' | 'archived'); the mapper's `as` cast at the read
// edge is what makes the DB-text → DTO-union narrowing safe.
//
// `diff` is JSON: the field-diff shape ({ title: { from, to }, … }) for
// create/update/archive, and the link-diff shape ({ links: { added: [...] } })
// for link/unlink. It is intentionally untyped at the DB layer — the DTO
// pins the wire shape.
//
// `onDelete: Restrict` on `changedById` mirrors WorkItem.reporter (1.4.2):
// revisions preserve history even after a user soft-deletes, so hard-deleting
// a user who ever changed an issue requires explicit handling (a future
// user-archive Story) rather than silently shredding the audit trail.
// `workItemId` cascades — when an issue is hard-deleted its history goes with
// it (work items are soft-archived in practice, so this is the rare path).
//
// NOTE: there is no `workspaceId` column by design — denormalizing tenancy
// onto a revision row would let it lie about which workspace it belongs to.
// The RLS policy (see the add_work_item_revisions migration) joins to the
// parent work_item instead.
model WorkItemRevision {
  id          String   @id @default(cuid())
  workItemId  String
  changedById String
  changedAt   DateTime @default(now())
  changeKind  String // 'created' | 'updated' | 'archived' — String, not enum (see model note)
  diff        Json

  workItem  WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  changedBy User     @relation("WorkItemRevisionAuthor", fields: [changedById], references: [id], onDelete: Restrict)

  @@index([workItemId, changedAt])
  @@index([workItemId])
  @@map("work_item_revision")
}

enum WorkItemLinkKind {
  is_blocked_by
  relates_to
  duplicates
  clones

  @@map("work_item_link_kind")
}

enum WorkItemKind {
  epic
  story
  task
  bug
  subtask

  @@map("work_item_kind")
}

enum WorkItemPriority {
  lowest
  low
  medium
  high
  highest

  @@map("work_item_priority")
}

enum WorkItemExplanationSource {
  user_authored
  ai_draft
  user_edited

  @@map("work_item_explanation_source")
}

// Background-job run ledger (Story 1.6 · Subtask 1.6.2). Every invocation of a
// `defineJob`-wrapped Inngest function writes ONE row here: a `running` row at
// start, flipped to `succeeded` / `failed` on completion. This is the read
// path the operator dashboard (1.6.5) renders WITHOUT calling Inngest's own
// API — Prodect owns its job-observability data.
//
// `workspaceId` is NULLABLE on purpose: most jobs are workspace-scoped (the
// durable invariant `sendEvent` enforces — every business event carries a
// workspaceId), but SYSTEM jobs (`system.ping` here, `system.daily-health-
// check` in 1.6.4) are untenanted and write a null-workspace row. The FK
// cascades: archiving/deleting a workspace removes its job-run history with it.
//
// RLS is DEFERRED to Subtask 1.6.4 — that Subtask folds the policy in alongside
// the dead-letter-queue table so the two land in one atomic migration-by-concern
// (mirrors PRODECT_FINDINGS #20's "create table + its policy in one migration"
// lesson; here the policy is deliberately batched with the DLQ work it belongs
// with, and until then job_run is reached ONLY through the trusted wrapper, never
// a tenant-facing query path).
//
// `status` is a Postgres enum (running / succeeded / failed) — the set is closed
// and stable, unlike `WorkItemRevision.changeKind` (left as text precisely
// because its value set is open). `failure` is JSON: `{ message, stack, code? }`.
// `idempotencyKey` is the rendered template (1.6.4 wires the dedup semantics;
// the column ships now so the dashboard + dedup land without a later migration).
model JobRun {
  id             String       @id @default(cuid())
  workspaceId    String?      @map("workspace_id")
  functionId     String       @map("function_id")
  eventName      String       @map("event_name")
  eventId        String       @map("event_id")
  attempt        Int
  status         JobRunStatus
  startedAt      DateTime     @default(now()) @map("started_at")
  finishedAt     DateTime?    @map("finished_at")
  durationMs     Int?         @map("duration_ms")
  failure        Json?
  idempotencyKey String?      @map("idempotency_key")

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // Dashboard read paths (1.6.5): newest-first per workspace, and the same
  // filtered by status. The eventId / idempotencyKey indexes serve the
  // correlation + dedup lookups (1.6.4).
  @@index([workspaceId, startedAt(sort: Desc)])
  @@index([workspaceId, status, startedAt(sort: Desc)])
  @@index([eventId])
  @@index([idempotencyKey])
  @@map("job_run")
}

enum JobRunStatus {
  running
  succeeded
  failed

  @@map("job_run_status")
}
