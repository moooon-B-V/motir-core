# Local dev DB (run `./scripts/db-up.sh` to start Postgres in Docker).
# Host port is 5433 (not 5432) to avoid conflicting with other local
# Postgres instances. The container internally uses 5432.
#
# This connects as `prodect`, the Docker-image superuser. A superuser has an
# implicit BYPASSRLS attribute, so the workspace RLS policies are INERT on this
# connection (they exist but never execute). That is acceptable for v1: the
# primary tenant-isolation defense is application-layer (always going through
# withWorkspaceContext + filtering by workspaceId); RLS is the secondary,
# defense-in-depth layer. See PRODECT_FINDINGS #5(deploy).
DATABASE_URL="postgresql://prodect:prodect@localhost:5433/prodect"

# RLS-enforcing runtime role (PRODECT_FINDINGS #5(deploy)). `prodect_app` is
# created NOSUPERUSER NOBYPASSRLS by the workspace-RLS migration and granted
# LOGIN by grant_prodect_app_login; `scripts/db-up.sh` sets its local dev
# password. Pointing DATABASE_URL at it makes the workspace RLS policies
# actually bite. NOT enabled yet: the test suite's fixtures assume superuser
# visibility for setup/teardown and need a two-client (admin-for-setup) rework
# before the cutover — tracked for Story 1.5's deploy hardening. To try it
# locally after that rework, swap the DATABASE_URL above for:
#   DATABASE_URL="postgresql://prodect_app:prodect_app@localhost:5433/prodect"
# In PRODUCTION, never use this literal password: the deploy / managed Postgres
# provider sets prodect_app's password from its secret store and the runtime
# DATABASE_URL is injected from there.

# Auth — Better-Auth (Story 1.1)
# BETTER_AUTH_SECRET: required. Used to sign session cookies. Generate a
# fresh 32-byte secret for each environment with:
#   openssl rand -base64 32
# In production, store this in the Vercel dashboard (Settings → Environment
# Variables). Rotating the secret invalidates all active sessions.
BETTER_AUTH_SECRET=

# BETTER_AUTH_URL: the public origin Better-Auth uses to build callback
# URLs (OAuth round-trips, email links). Optional in local dev — defaults
# to http://localhost:3000 — but MUST be set in production to the canonical
# public URL (e.g. https://motir-core.vercel.app). Setting Vercel's
# automatic VERCEL_URL is not enough because it omits the protocol.
# BETTER_AUTH_URL=http://localhost:3000

# Email provider — see lib/email.ts for the abstraction.
# 'console' (default) prints emails to stdout so dev/test flows can grep
# the reset link. Production providers ('resend', 'postmark', …) are NOT
# YET WIRED in motir-core: choosing and configuring a real mailer is
# planner work for each Motir-planned project's pre-plan phase, where
# the planner has the project-specific context (compliance, domain
# verification, sender identity) to pick the right one. Setting one of
# the un-wired values will throw at module load with a clear message.
EMAIL_PROVIDER=console

# Google OAuth (Subtask 1.1.4) — required. The Google "Continue with Google"
# button needs both. Obtain them at:
#   Google Cloud Console → APIs & Services → Credentials
#     → Create Credentials → OAuth 2.0 Client ID → Web application
# Authorized redirect URI to enter at Google:
#   {BETTER_AUTH_URL}/api/auth/callback/google
#   (local dev: http://localhost:3000/api/auth/callback/google)
# Each Motir-planned project supplies its OWN values — no shared defaults
# ship with the starter or with motir-core. Missing values throw at
# module-load time so misconfiguration surfaces loudly, not at click time.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub integration (Story 7.10 · MOTIR-1498) — the OAuth user-identity grant.
# These are the OAuth half of the Motir GitHub App: the client id/secret used to
# exchange the callback code for a user access token and read the member's
# GitHub identity (`/api/github/oauth/start` → `/callback`). The App-installation
# keys (App id, private key, webhook secret) land with the installation grant
# (MOTIR-891). Register the App at GitHub → Settings → Developer settings →
# GitHub Apps; the callback URL to enter is
#   {BETTER_AUTH_URL}/api/github/oauth/callback
#   (local dev: http://localhost:3000/api/github/oauth/callback)
# Optional: unset means the GitHub connect flow is simply unreachable (the
# routes redirect with ?github=not_configured) — a self-hosted instance that
# doesn't use GitHub needs none of these and won't crash without them.
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
# Symmetric key that encrypts the stored GitHub user access token at rest
# (AES-256-GCM, lib/github/tokenCrypto.ts). REQUIRED whenever the GitHub OAuth
# keys above are set — the callback can't persist an identity without it.
# Provide 64 hex chars OR a 32-byte base64 value. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Rotating it makes every previously-stored GitHub token undecryptable (members
# re-connect); treat it like BETTER_AUTH_SECRET.
GITHUB_TOKEN_ENCRYPTION_KEY=

# Symmetric key that encrypts stored IMPORT-SOURCE OAuth tokens at rest (Jira /
# Linear / Plane connect flows — Story 7.16, lib/crypto/tokenCrypto.ts). OPTIONAL:
# when unset it falls back to GITHUB_TOKEN_ENCRYPTION_KEY, so a deployment that
# already configured GitHub needs no new key. Set a DEDICATED key (same 64-hex /
# 32-byte-base64 format) to isolate import tokens from the GitHub key. Rotating it
# makes previously-stored import tokens undecryptable (members re-connect).
IMPORT_TOKEN_ENCRYPTION_KEY=

# GitHub App installation grant (MOTIR-891) — "Grant 2". Server-to-server App
# credentials used to mint short-lived INSTALLATION access tokens (scoped to the
# installation's repos, NEVER stored — lib/github/appAuth.ts) and to verify
# inbound webhooks. Distinct from the OAuth identity half above. Optional: unset
# means the installation flow is simply unreachable (a self-hosted instance that
# doesn't use GitHub needs none of these and won't crash without them).
GITHUB_APP_ID=
# The App private key (PEM, from GitHub → the App → "Generate a private key").
# Newlines may be escaped as \n (restored at read time) or kept literal in a
# quoted multi-line value.
GITHUB_APP_PRIVATE_KEY=
# Shared secret configured on the GitHub App's webhook — used to verify inbound
# webhook signatures (consumed by the webhook route, MOTIR-892).
GITHUB_WEBHOOK_SECRET=

# Background jobs — Inngest (Story 1.6). The serve route lives at
# /api/inngest; jobs are defined via lib/jobs/defineJob and emitted via
# lib/jobs/sendEvent.
#
# INNGEST_DEV: set to "1" for LOCAL development ONLY. Without it, Inngest's
# serve route defaults to CLOUD mode and 500s locally ("in cloud mode but no
# signing key found"). The `pnpm dev:inngest` script sets it for you; leave it
# UNSET in preview/production. Start the local dev server with:
#   pnpm dev:inngest        # next dev with INNGEST_DEV=1
#   npx inngest-cli@latest dev -u http://localhost:3000/api/inngest
INNGEST_DEV=1
#
# INNGEST_SIGNING_KEY / INNGEST_EVENT_KEY: required in PREVIEW + PRODUCTION,
# NOT in local dev (the local dev server doesn't need them). Provision them via
# the official Inngest↔Vercel integration, which ALSO configures the Vercel
# Deployment-Protection bypass the Inngest control plane needs to reach
# protected preview deployments (PRODECT_FINDINGS #30, sharp edge #8 — without
# the bypass, /api/inngest 401s and the keys are inert). Leave blank locally.
INNGEST_SIGNING_KEY=
INNGEST_EVENT_KEY=

# PLATFORM_ADMIN_EMAIL: the operator dashboard's pre-Epic-6 escape hatch
# (Subtask 1.6.5). When the signed-in user's email matches this value, the
# /settings/workspace/jobs dashboard shows a "System" tab listing job runs
# across ALL workspaces (including untenanted system jobs). Leave UNSET for
# normal deployments — without it, no one sees the System tab and every user is
# scoped to their own workspace's runs. To be replaced by real platform-admin
# roles in Epic 6 (PRODECT_FINDINGS #36).
PLATFORM_ADMIN_EMAIL=

# Backend AI service — used in Epic 4 to call motir-ai server-to-server
# MOTIR_AI_URL=http://localhost:8001
# MOTIR_AI_INTERNAL_KEY=

# Shared service bearer for motir-ai → motir-core calls (open-core boundary,
# Story 8.1). Authenticates the inbound billing-propagation route
# POST /api/internal/billing/scaled-tracker-state (8.1.4c); the SAME value is set
# on motir-ai's coreClient (8.1.4d). The route fails CLOSED when unset (rejects
# every request), so leave it unset locally unless exercising the cross-service
# path. Stripe secrets never enter motir-core — only plain subscription state.
# MOTIR_AI_TO_CORE_SERVICE_TOKEN=

# Cross-origin allowlist for the public POST /api/idea-draft receiver (Subtask
# 7.22.2 / MOTIR-1458). The standalone motir-marketing site (motir.co, a DIFFERENT
# origin) forwards a logged-out visitor's hero idea to this endpoint. List the
# exact allowed origin(s), comma-separated (no trailing slash), e.g.
# `https://motir.co,https://www.motir.co`. Leave UNSET to fail CLOSED — the
# endpoint then rejects every cross-origin caller (same-origin calls carry no
# Origin header and are unaffected). Locally set your marketing dev origin (e.g.
# http://localhost:3001) to exercise the handoff.
# MOTIR_MARKETING_ORIGIN=

# Vercel Blob — description/attachment uploads (Story 2.3.7). On Vercel this is
# auto-wired by connecting a Blob store to the project (Subtask 2.3.9); locally,
# `vercel env pull` or paste the store's token here. A placeholder is enough for
# build + unit tests (the Blob SDK is mocked in tests); a REAL token is only
# needed to actually upload (the Vercel preview has it).
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_PLACEHOLDER_build_only
